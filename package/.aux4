{
  "scope": "aux4",
  "name": "ai-agent",
  "version": "0.1.37",
  "description": "AI agent",
  "tags": [
    "ai",
    "agent",
    "llm"
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "ai",
          "execute": [
            "profile:ai"
          ],
          "help": {
            "text": "Artificial Intelligence"
          }
        }
      ]
    },
    {
      "name": "ai",
      "commands": [
        {
          "name": "agent",
          "execute": [
            "profile:ai:agent"
          ],
          "help": {
            "text": "Artificial Intelligence Agent"
          }
        }
      ]
    },
    {
      "name": "ai:agent",
      "commands": [
        {
          "name": "learn",
          "execute": [
            "node ${packageDir}/lib/aux4-ai-agent.cjs learn values(storage, doc, type)"
          ],
          "help": {
            "text": "Learn from a document or folder",
            "variables": [
              {
                "name": "storage",
                "text": "The storage directory",
                "default": ".context"
              },
              {
                "name": "doc",
                "text": "The document or folder to learn from",
                "arg": true
              },
              {
                "name": "type",
                "text": "The type of document",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "search",
          "execute": [
            "node ${packageDir}/lib/aux4-ai-agent.cjs search values(storage, format, source, limit, query)"
          ],
          "help": {
            "text": "Search on documents",
            "variables": [
              {
                "name": "storage",
                "text": "The storage directory",
                "default": ".context"
              },
              {
                "name": "format",
                "text": "The format of the output",
                "default": "text",
                "options": [
                  "json",
                  "text"
                ]
              },
              {
                "name": "source",
                "text": "The source file path",
                "default": ""
              },
              {
                "name": "limit",
                "text": "The number of results to return",
                "default": "1"
              },
              {
                "name": "query",
                "text": "The query to search for",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "forget",
          "execute": [
            "node ${packageDir}/lib/aux4-ai-agent.cjs forget values(storage, doc)"
          ],
          "help": {
            "text": "Forget learned documents",
            "variables": [
              {
                "name": "storage",
                "text": "The storage directory",
                "default": ".context"
              },
              {
                "name": "doc",
                "text": "File or folder to forget (all if omitted)",
                "default": "",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "ask",
          "execute": [
            "stdin:node ${packageDir}/lib/aux4-ai-agent.cjs ask values(baseInstructions, instructions, role, history, outputSchema, question, image, context, model, storage, stream, autoCompact, compaction, bio)"
          ],
          "help": {
            "text": "Ask your question",
            "variables": [
              {
                "name": "baseInstructions",
                "text": "Base instructions file loaded before the main instructions",
                "default": ""
              },
              {
                "name": "instructions",
                "text": "The instructions file of the prompt",
                "default": "instructions.md"
              },
              {
                "name": "role",
                "text": "The role of the user",
                "default": "user"
              },
              {
                "name": "history",
                "text": "The file to use as history",
                "default": ""
              },
              {
                "name": "outputSchema",
                "text": "The file that represents the JSON schema of the output",
                "default": "schema.json"
              },
              {
                "name": "context",
                "text": "Read context from stdin",
                "default": "false"
              },
              {
                "name": "image",
                "text": "The image path, if more than one, separate with comma",
                "default": ""
              },
              {
                "name": "storage",
                "text": "The storage directory",
                "default": ".context"
              },
              {
                "name": "stream",
                "text": "Enable streaming output",
                "default": "false"
              },
              {
                "name": "autoCompact",
                "text": "Enable auto-compaction of conversation history",
                "default": "false"
              },
              {
                "name": "compaction",
                "text": "Compaction configuration as JSON",
                "default": "{}"
              },
              {
                "name": "bio",
                "text": "Agent bio as JSON (name, role, description, picture)",
                "default": ""
              },
              {
                "name": "question",
                "text": "The question to ask",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "image",
          "execute": [
            "node ${packageDir}/lib/aux4-ai-agent.cjs image values(prompt, image, size, quality, context, model, quantity)"
          ],
          "help": {
            "text": "Generate an image from a text prompt",
            "variables": [
              {
                "name": "prompt",
                "text": "The text prompt describing the image to generate",
                "arg": true
              },
              {
                "name": "image",
                "text": "The file path where to save the generated image"
              },
              {
                "name": "size",
                "text": "The image size (e.g., 1024x1024, 1792x1024, 1024x1792)",
                "default": "1024x1024"
              },
              {
                "name": "quality",
                "text": "The image quality (DALL-E: standard/hd, gpt-image: low/medium/high/auto)",
                "default": "auto",
                "options": [
                  "standard",
                  "hd",
                  "low",
                  "medium",
                  "high",
                  "auto"
                ]
              },
              {
                "name": "context",
                "text": "Read additional context from stdin",
                "default": "false"
              },
              {
                "name": "model",
                "text": "Model configuration as JSON (e.g., {\"type\":\"openai\",\"config\":{\"model\":\"dall-e-3\"}})",
                "default": "{}"
              },
              {
                "name": "quantity",
                "text": "Number of images to generate (creates numbered files if > 1)",
                "default": "1"
              }
            ]
          }
        },
        {
          "name": "chat",
          "execute": [
            "set:question=${text}",
            "log:> ${text}",
            "stdin:aux4 ai agent ask params(instructions, role, history, outputSchema, text, image, context, question, model, storage, stream, autoCompact, compaction, bio)",
            "stdin:if(text==exit) && echo exit || aux4 ai agent chat params(instructions, role, history, outputSchema, image, context, model, storage, autoCompact, compaction, bio)"
          ],
          "help": {
            "text": "Chat with the AI agent",
            "variables": [
              {
                "name": "instructions",
                "text": "The instructions file of the prompt",
                "default": "instructions.md"
              },
              {
                "name": "role",
                "text": "The role of the user",
                "default": "user"
              },
              {
                "name": "history",
                "text": "The file to use as history",
                "default": "history.json"
              },
              {
                "name": "outputSchema",
                "text": "The file that represents the JSON schema of the output",
                "default": "schema.json"
              },
              {
                "name": "context",
                "text": "Read context from stdin",
                "default": "false"
              },
              {
                "name": "image",
                "text": "The image path, if more than one, separate with comma",
                "default": ""
              },
              {
                "name": "storage",
                "text": "The storage directory",
                "default": ".context"
              },
              {
                "name": "model",
                "text": "Model configuration as JSON (e.g., {\"type\":\"openai\",\"config\":{\"model\":\"gpt-4\"}})",
                "default": "{}"
              },
              {
                "name": "autoCompact",
                "text": "Enable auto-compaction of conversation history",
                "default": "false"
              },
              {
                "name": "compaction",
                "text": "Compaction configuration as JSON",
                "default": "{}"
              },
              {
                "name": "bio",
                "text": "Agent bio as JSON (name, role, description, picture)",
                "default": ""
              },
              {
                "name": "text",
                "text": "The text",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "history",
          "execute": [
            "node ${packageDir}/lib/aux4-ai-agent.cjs history values(historyFile)"
          ],
          "help": {
            "text": "Display a formatted view of conversation history",
            "variables": [
              {
                "name": "historyFile",
                "text": "The history JSON file to display",
                "default": "history.json",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "summarize",
          "execute": [
            "node ${packageDir}/lib/aux4-ai-agent.cjs summarize values(historyFile, model)"
          ],
          "help": {
            "text": "Summarize conversation history as markdown",
            "variables": [
              {
                "name": "historyFile",
                "text": "The history JSON file to summarize",
                "default": "history.json",
                "arg": true
              },
              {
                "name": "model",
                "text": "Model configuration as JSON",
                "default": "{}"
              }
            ]
          }
        },
        {
          "name": "remember",
          "execute": [
            "node ${packageDir}/lib/aux4-ai-agent.cjs remember values(historyFile, model)"
          ],
          "help": {
            "text": "Generate a concise memory entry from conversation history",
            "variables": [
              {
                "name": "historyFile",
                "text": "The history JSON file",
                "default": "history.json",
                "arg": true
              },
              {
                "name": "model",
                "text": "Model configuration as JSON",
                "default": "{}"
              }
            ]
          }
        },
        {
          "name": "compact",
          "execute": [
            "node ${packageDir}/lib/aux4-ai-agent.cjs compact values(historyFile, model, keepLastMessages)"
          ],
          "help": {
            "text": "Compact conversation history by summarizing older messages",
            "variables": [
              {
                "name": "historyFile",
                "text": "The history JSON file to compact",
                "default": "history.json",
                "arg": true
              },
              {
                "name": "model",
                "text": "Model configuration as JSON",
                "default": "{}"
              },
              {
                "name": "keepLastMessages",
                "text": "Number of recent messages to keep verbatim",
                "default": "6"
              }
            ]
          }
        }
      ]
    }
  ]
}
